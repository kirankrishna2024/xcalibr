# XCalibr Backend Environment Variables
# Copy this file to .env and fill in your values

# IMPORTANT: The key must be lowercase 'database_url' (matches config.py)
database_url=postgresql://postgres:YOUR_PASSWORD@localhost:5432/xcalibr_db

# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
